<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("submit-btn");
        if (btn) {
            btn.addEventListener("click", () => {
                btn.textContent = "✓ Message sent — I'll be in touch!";
                btn.style.background = "#28c840";
                btn.style.color = "#fff";
                btn.disabled = true;
                setTimeout(() => {
                    btn.innerHTML =
                        '<svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg> Send Message';
                    btn.style.background = "";
                    btn.style.color = "";
                    btn.disabled = false;
                }, 4000);
            });
        }
    });
</script>
