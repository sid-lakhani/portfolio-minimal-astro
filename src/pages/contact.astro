---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Contact — Siddhesh Lakhani"
    description="Get in touch with Siddhesh Lakhani — open to freelance, full-time, and collab."
    activePage="contact"
>
    <div class="page-wrap">
        <div class="contact-hero">
            <div class="grid-bg"></div>
            <div class="contact-hero-inner">
                <div class="section-tag">Get In Touch</div>
                <h1 class="section-h">
                    Let's build<br /><span style="color:var(--red)"
                        >something.</span>
                </h1>
                <p class="section-sub">
                    Open to freelance projects, full-time roles, and interesting
                    collaborations. If you have a problem worth solving, I'm in.
                </p>
            </div>
        </div>

        <div class="contact-layout">
            <!-- LEFT COLUMN -->
            <div class="contact-info">
                <div class="avail-card">
                    <div class="avail-dot"></div>
                    <div class="avail-text">
                        <strong>Available for Work</strong>
                        <span
                            >Open to freelance, full-time & collabs — Mumbai /
                            Remote</span
                        >
                    </div>
                </div>

                <div class="resume-cta">
                    <div class="resume-cta-text">
                        <strong>Download My Resume</strong>
                        <span>PDF — Full Stack Engineer, updated 2025</span>
                    </div>
                    <a href="/Resume.pdf" target="_blank" class="btn-resume">
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"
                            ></path></svg
                        >
                        Resume.pdf
                    </a>
                </div>

                <div class="contact-methods">
                    <a
                        href="mailto:lakhani.siddhesh@gmail.com"
                        class="contact-method"
                    >
                        <div class="contact-method-icon">
                            <svg viewBox="0 0 24 24"
                                ><path
                                    d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-.222.046-.433.128-.625L6.91 10.09 12 13.82l5.09-3.73 6.782-5.258c.082.192.128.403.128.625z"
                                ></path></svg
                            >
                        </div>
                        <div>
                            <div class="contact-method-label">Email</div>
                            <div class="contact-method-value">
                                lakhani.siddhesh@gmail.com
                            </div>
                        </div>
                    </a>
                    <a
                        href="https://linkedin.com/in/siddhesh-lakhani"
                        target="_blank"
                        class="contact-method"
                    >
                        <div class="contact-method-icon">
                            <svg viewBox="0 0 24 24"
                                ><path
                                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                                ></path></svg
                            >
                        </div>
                        <div>
                            <div class="contact-method-label">LinkedIn</div>
                            <div class="contact-method-value">
                                in/siddhesh-lakhani
                            </div>
                        </div>
                    </a>
                    <a
                        href="https://github.com/sid-lakhani"
                        target="_blank"
                        class="contact-method"
                    >
                        <div class="contact-method-icon">
                            <svg viewBox="0 0 24 24"
                                ><path
                                    d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                                ></path></svg
                            >
                        </div>
                        <div>
                            <div class="contact-method-label">GitHub</div>
                            <div class="contact-method-value">
                                github.com/sid-lakhani
                            </div>
                        </div>
                    </a>
                    <a
                        href="https://instagram.com/sidlakhani_"
                        target="_blank"
                        class="contact-method"
                    >
                        <div class="contact-method-icon">
                            <svg viewBox="0 0 24 24"
                                ><path
                                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                                ></path></svg
                            >
                        </div>
                        <div>
                            <div class="contact-method-label">Instagram</div>
                            <div class="contact-method-value">@sidlakhani_</div>
                        </div>
                    </a>
                </div>

                <div class="social-big">
                    <a
                        href="https://github.com/sid-lakhani"
                        target="_blank"
                        class="social-big-btn"
                    >
                        <svg viewBox="0 0 24 24"
                            ><path
                                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                            ></path></svg
                        >
                        GitHub
                    </a>
                    <a
                        href="https://linkedin.com/in/siddhesh-lakhani"
                        target="_blank"
                        class="social-big-btn"
                    >
                        <svg viewBox="0 0 24 24"
                            ><path
                                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                            ></path></svg
                        >
                        LinkedIn
                    </a>
                    <a
                        href="https://instagram.com/sidlakhani_"
                        target="_blank"
                        class="social-big-btn"
                    >
                        <svg viewBox="0 0 24 24"
                            ><path
                                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
                            ></path></svg
                        >
                        Instagram
                    </a>
                </div>
            </div>

            <!-- RIGHT — FORM -->
            <div class="contact-form-wrap">
                <div
                    style="background:var(--char2);border:1px solid var(--border);border-radius:12px;padding:36px;"
                >
                    <div class="section-tag" style="margin-bottom:20px;">
                        Send a Message
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Name</label>
                            <input
                                type="text"
                                class="form-input"
                                placeholder="Your name"
                            />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input
                                type="email"
                                class="form-input"
                                placeholder="you@example.com"
                            />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Subject</label>
                        <input
                            type="text"
                            class="form-input"
                            placeholder="What's this about?"
                        />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Type</label>
                        <select class="form-input" style="cursor:pointer;">
                            <option value="" disabled selected
                                >Select inquiry type</option
                            >
                            <option>Freelance Project</option>
                            <option>Full-Time Opportunity</option>
                            <option>Collaboration</option>
                            <option>Just Saying Hi</option>
                            <option>Other</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Message</label>
                        <textarea
                            class="form-textarea"
                            placeholder="Tell me about your project, idea, or whatever's on your mind..."
                        ></textarea>
                    </div>
                    <button class="form-submit" id="submit-btn">
                        <svg
                            width="14"
                            height="14"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            ><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"
                            ></path></svg
                        >
                        Send Message
                    </button>
                    <p class="form-note">
                        Usually respond within 24 hours. Or reach me directly at <a
                            href="mailto:lakhani.siddhesh@gmail.com"
                            style="color:var(--red);text-decoration:none;"
                            >lakhani.siddhesh@gmail.com</a>
                    </p>
                </div>
            </div>
        </div>

        <!-- OPEN TO -->
        <div class="open-to">
            <div class="section-tag">What I'm Open To</div>
            <h2 class="section-h" style="margin-bottom:4px;">
                Let's collaborate<br /><span style="color:var(--red)"
                    >on something real.</span>
            </h2>
            <div class="open-to-grid">
                <div class="open-card">
                    <div class="open-icon">🚀</div>
                    <div class="open-title">Freelance Projects</div>
                    <div class="open-desc">
                        Full-stack web apps, APIs, self-hosted solutions, or
                        anything production-grade. Got a problem? Let's build
                        it.
                    </div>
                </div>
                <div class="open-card">
                    <div class="open-icon">💼</div>
                    <div class="open-title">Full-Time Roles</div>
                    <div class="open-desc">
                        Looking for full-stack or backend-heavy roles at product
                        companies. Remote-first or Mumbai-based.
                    </div>
                </div>
                <div class="open-card">
                    <div class="open-icon">🤝</div>
                    <div class="open-title">Collaborations</div>
                    <div class="open-desc">
                        Open source, side projects, or interesting experiments.
                        If the idea's cool, I'm in.
                    </div>
                </div>
            </div>
        </div>
    </div>
</BaseLayout>

<style>
    /* CONTACT PAGE */
    .contact-hero {
        padding: 120px 52px 60px;
        position: relative;
        overflow: hidden;
    }
    .contact-hero .grid-bg {
        opacity: 0.5;
    }
    .contact-hero-inner {
        position: relative;
        z-index: 2;
    }
    .contact-hero-inner .section-h {
        margin-top: 12px;
    }

    /* LAYOUT */
    .contact-layout {
        padding: 0 52px 96px;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 64px;
        align-items: start;
    }

    /* LEFT — info */
    .contact-blurb {
        font-size: 16px;
        color: var(--muted);
        line-height: 1.8;
        margin-bottom: 40px;
    }
    .contact-blurb strong {
        color: var(--off);
    }

    /* AVAILABILITY */
    .avail-card {
        background: var(--char2);
        border: 1px solid var(--red-border);
        border-radius: 10px;
        padding: 24px;
        margin-bottom: 32px;
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .avail-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--red);
        flex-shrink: 0;
        box-shadow: 0 0 10px rgba(255, 59, 59, 0.5);
        animation: blink 2s ease-in-out infinite;
    }
    @keyframes blink {
        0%,
        100% {
            opacity: 1;
            box-shadow: 0 0 10px rgba(255, 59, 59, 0.5);
        }
        50% {
            opacity: 0.5;
            box-shadow: 0 0 4px rgba(255, 59, 59, 0.2);
        }
    }
    .avail-text strong {
        font-size: 14px;
        font-weight: 700;
        display: block;
        color: var(--off);
        margin-bottom: 2px;
    }
    .avail-text span {
        font-size: 12px;
        color: var(--muted);
    }

    /* CONTACT LINKS */
    .contact-methods {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 36px;
    }
    .contact-method {
        display: flex;
        align-items: center;
        gap: 14px;
        background: var(--char2);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 14px 18px;
        text-decoration: none;
        color: inherit;
        transition:
            border-color 0.2s,
            transform 0.15s;
    }
    .contact-method:hover {
        border-color: var(--red-border);
        transform: translateX(4px);
    }
    .contact-method-icon {
        width: 36px;
        height: 36px;
        border-radius: 7px;
        background: var(--red-faint);
        border: 1px solid var(--red-border);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .contact-method-icon svg {
        width: 16px;
        height: 16px;
        fill: var(--red);
    }
    .contact-method-label {
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
    }
    .contact-method-value {
        font-size: 14px;
        font-weight: 600;
        color: var(--off);
    }

    /* SOCIAL BIG BUTTONS */
    .social-big {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 10px;
        margin-top: 8px;
    }
    .social-big-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        padding: 18px 12px;
        background: var(--char2);
        border: 1px solid var(--border);
        border-radius: 10px;
        text-decoration: none;
        color: var(--muted);
        transition: all 0.2s;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }
    .social-big-btn:hover {
        border-color: var(--red-border);
        color: var(--red);
        background: var(--red-faint);
    }
    .social-big-btn svg {
        width: 20px;
        height: 20px;
        fill: currentColor;
    }

    /* RESUME DOWNLOAD CTA */
    .resume-cta {
        background: var(--char2);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 28px;
        margin-bottom: 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
    }
    .resume-cta-text strong {
        font-size: 16px;
        font-weight: 700;
        display: block;
        color: var(--off);
        margin-bottom: 4px;
    }
    .resume-cta-text span {
        font-size: 13px;
        color: var(--muted);
    }
    .btn-resume {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: var(--red);
        color: var(--char);
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.06em;
        padding: 12px 24px;
        border-radius: 8px;
        text-decoration: none;
        white-space: nowrap;
        transition:
            background 0.2s,
            transform 0.15s;
    }
    .btn-resume:hover {
        background: var(--red-dim);
        transform: translateY(-2px);
    }

    /* RIGHT — form */
    .form-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 8px;
        display: block;
    }
    .form-group {
        margin-bottom: 20px;
    }
    .form-input,
    .form-textarea {
        width: 100%;
        background: var(--char2);
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--off);
        font-family: "Space Grotesk", sans-serif;
        font-size: 14px;
        padding: 12px 16px;
        transition: border-color 0.2s;
        outline: none;
    }
    .form-input:focus,
    .form-textarea:focus {
        border-color: var(--red-border);
    }
    .form-textarea {
        min-height: 140px;
        resize: vertical;
        line-height: 1.6;
    }
    .form-input::placeholder,
    .form-textarea::placeholder {
        color: var(--muted);
        opacity: 0.6;
    }
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }
    .form-submit {
        width: 100%;
        background: var(--red);
        color: var(--char);
        font-family: "Space Grotesk", sans-serif;
        font-size: 14px;
        font-weight: 700;
        letter-spacing: 0.05em;
        padding: 14px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition:
            background 0.2s,
            transform 0.15s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }
    .form-submit:hover {
        background: var(--red-dim);
        transform: translateY(-2px);
    }
    .form-note {
        font-size: 12px;
        color: var(--muted);
        margin-top: 12px;
        text-align: center;
        line-height: 1.5;
    }

    /* OPEN TO section */
    .open-to {
        padding: 0 52px 96px;
    }
    .open-to-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-top: 40px;
    }
    .open-card {
        background: var(--char2);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 24px;
        transition: border-color 0.2s;
    }
    .open-card:hover {
        border-color: var(--red-border);
    }
    .open-icon {
        font-size: 22px;
        margin-bottom: 14px;
    }
    .open-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--off);
        margin-bottom: 6px;
    }
    .open-desc {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.6;
    }

    @media (max-width: 900px) {
        .contact-layout,
