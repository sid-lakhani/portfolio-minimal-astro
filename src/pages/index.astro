              ></path></svg
            ></a
          >
          <a
            href="https://instagram.com/sidlakhani_"
            target="_blank"
            class="social-btn"
            ><svg viewBox="0 0 24 24"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"
              ></path></svg
            ></a
          >
        </div>
      </div>
    </div>
  </section>

  <!-- TICKER -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <span class="tick-item">Next.js</span><span class="tick-item">React</span>
      <span class="tick-item">TypeScript</span><span class="tick-item"
        >Express</span
      >
      <span class="tick-item">Node.js</span><span class="tick-item"
        >PostgreSQL</span
      >
      <span class="tick-item">Docker</span><span class="tick-item">Rust</span>
      <span class="tick-item">Arch Linux</span><span class="tick-item"
        >Nginx</span
      >
      <span class="tick-item">Prisma</span>
      <span class="tick-item">TailwindCSS</span><span class="tick-item"
        >Python</span
      >
      <span class="tick-item">DWM</span><span class="tick-item">OpenCV</span>
      <span class="tick-item">Next.js</span><span class="tick-item">React</span>
      <span class="tick-item">TypeScript</span><span class="tick-item"
        >Express</span
      >
      <span class="tick-item">Node.js</span><span class="tick-item"
        >PostgreSQL</span
      >
      <span class="tick-item">Docker</span><span class="tick-item">Rust</span>
      <span class="tick-item">Arch Linux</span><span class="tick-item"
        >Nginx</span
      >
      <span class="tick-item">Prisma</span>
      <span class="tick-item">TailwindCSS</span><span class="tick-item"
        >Python</span
      >
      <span class="tick-item">DWM</span><span class="tick-item">OpenCV</span>
    </div>
  </div>

  <!-- ABOUT STRIP -->
  <div class="about-strip">
    <div class="about-strip-left">
      <div class="section-tag">01 — About</div>
      <h2 class="section-h">
        Minimalism<br />meets<br /><span style="color:var(--red)"
          >Performance.</span
        >
      </h2>
      <p class="section-sub">
        I ship fast, self-host everything, and believe you should own your
        stack.
      </p>
      <div class="ctas">
        <a href="/about" class="btn-primary">More About Me</a>
        <a href="/Resume.pdf" target="_blank" class="btn-outline"
          >Resume <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            style="margin-left: 2px"
            ><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg
          ></a
        >
      </div>
    </div>
    <div class="about-strip-right">
      <div class="about-prose">
        <p>
          I'm a <strong>Full Stack Engineer</strong> from Mumbai, building scalable
          systems with Next.js, Express, PostgreSQL, and Docker. I focus on performance,
          simplicity, and clean architecture.
        </p>
        <p>
          I work close to the system — exploring <strong>Linux internals</strong
          >, running a custom <strong>DWM setup</strong> on Arch, and prioritizing
          control, efficiency, and minimalism across the stack.
        </p>
      </div>
      <div class="mini-terminal">
        <div class="mini-terminal-bar">
          <div class="t-dot t-red"></div>
          <div class="t-dot t-yellow"></div>
          <div class="t-dot t-green"></div>
        </div>
        <div class="mini-terminal-body">
          <div class="terminal-content">
            <div class="terminal-left">
              <pre
                class="arch-ascii">
                  <span class="tr">-`</span>
                 <span class="tr">.o+`</span>
                <span class="tr">`ooo/</span>
               <span class="tr">`+oooo:</span>
              <span class="tr">`+oooooo:</span>
              <span class="tr">-+oooooo+:</span>
            <span class="tr">`/:-:++oooo+:</span>
           <span class="tr">`/++++/+++++++:</span>
          <span class="tr">`/++++++++++++++:</span>
         <span class="tr">`/+++o</span><span class="tv">oooooooo</span><span class="tr">oooo/`</span>
        <span class="tr">./</span><span class="tv">ooosssso++osssssso</span><span class="tr">+`</span>
<span class="tv">       .oossssso-````/ossssss+`</span>
      <span class="tv">-osssssso.      :ssssssso.</span>
     <span class="tv">:osssssss/        osssso+++.</span>
    <span class="tv">/ossssssss/        +ssssooo/-</span>
  <span class="tv">`/ossssso+/:-        -:/+osssso+-</span>
 <span class="tv">`+sso+:-`                 `.-/+oso:</span>
<span class="tv">`++:.                           `-/+/</span>
<span class="tv">.`                                 `/</span></pre>
            </div>
            <div class="terminal-right">
              <div class="t-line">
                <span class="tc">user@host</span><span class="tg"
                  >: sid@arch</span
                >
              </div>
              <div class="t-line">
                <span class="tc">os</span><span class="tv"
                  >: Arch Linux x86_64</span
                >
              </div>
              <div class="t-line">
                <span class="tc">shell</span><span class="tv">: zsh 5.9</span>
              </div>
              <div class="t-line">
                <span class="tc">wm</span><span class="tv">: DWM (patched)</span
                >
              </div>
              <div class="t-line">
                <span class="tc">location</span><span class="tv"
                  >: Mumbai, IN</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- SELECTED WORK -->
  <div class="work-section">
    <div class="work-header">
      <div>
        <div class="section-tag">02 — Work</div>
        <h2 class="section-h">Selected<br />Projects.</h2>
      </div>
      <a href="/projects" class="btn-outline">All Projects →</a>
    </div>
    <div class="work-grid">
      {
        featured.map((project, index) => (
          <a
            href={project.data.live || project.data.github || "/projects"}
            target={
              project.data.live || project.data.github ? "_blank" : undefined
            }
            class={index === 0 ? "wcard featured" : "wcard"}
          >
            <span class="wcard-arrow">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                style="margin-left: 2px"
              >
                <>
                  <path d="M7 17L17 7" />
                  <path d="M7 7h10v10" />
                </>
              </svg>
            </span>
            <div class="wcard-num">
              {index === 0 ? "Featured" : String(index + 1).padStart(2, "0")}
            </div>
            <h3 class="wcard-title">{project.data.title}</h3>
            <p class="wcard-desc">{project.data.description}</p>
            <div class="wcard-tags">
              {project.data.tags.map((tag) => (
                <span class="wcard-tag">{tag}</span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <!-- PROCESS -->
  <div class="process-strip">
    <div class="section-tag">03 — UNFILTERED</div>
    <h2 class="section-h">How I actually work.</h2>
    <div class="process-grid">
      <div class="proc-item">
        <div class="proc-step">01</div>
        <div class="proc-title">I break things on purpose</div>
        <div class="proc-desc">
          I don’t trust systems I haven’t broken myself. If it survives real
          stress, edge cases, and bad inputs — then it’s ready for production.
        </div>
      </div>

      <div class="proc-item">
        <div class="proc-step">02</div>
        <div class="proc-title">Terminal > UI</div>
        <div class="proc-desc">
          If there’s a GUI, I’m probably avoiding it. SSH, logs, and configs
          give me more control than any dashboard ever will.
        </div>
      </div>

      <div class="proc-item">
        <div class="proc-step">03</div>
        <div class="proc-title">Music = throughput</div>
        <div class="proc-desc">
          Lo-fi, techno, or chaos — depends on the bug. Flow state isn’t
          optional; it’s something I deliberately maintain while building.
        </div>
      </div>

      <div class="proc-item">
        <div class="proc-step">04</div>
        <div class="proc-title">Sleep is negotiable</div>
        <div class="proc-desc">
          If something’s almost done, I’m not stopping. Momentum matters more
          than comfort. Shipping always comes first.
        </div>
      </div>
    </div>
  </div>

  <!-- CURRENTLY -->
  <div class="currently-strip">
    <div>
      <div class="section-tag">04 — Right Now</div>
      <h2 class="section-h">
        What I'm<br /><span style="color:var(--red)">up to.</span>
      </h2>
      <p class="section-sub" style="margin-top:16px;">
        Real-time status — what's occupying my brain and hands this month.
      </p>
    </div>
    <div class="currently-items">
      <div class="curr-item">
        <span class="curr-badge">Learning</span>
        <p class="curr-text">
          <strong>Linux kernel internals</strong> — understanding syscalls, memory
          management, the scheduler. Going deeper than userspace.
        </p>
      </div>
      <div class="curr-item">
        <span class="curr-badge">Building</span>
        <p class="curr-text">
          <strong>Self-hosting stack</strong> — Nginx, Docker Compose, Cloudflare
          tunnels. Own your infra, own your data.
        </p>
      </div>
      <div class="curr-item">
        <span class="curr-badge">Exploring</span>
        <p class="curr-text">
          <strong>Systems programming</strong> — lower-level abstractions with C and
          Rust. Building more focus on efficiency.
        </p>
      </div>
      <div class="curr-item">
        <span class="curr-badge">Open To</span>
        <p class="curr-text">
          <strong>Freelance & discussions</strong> — interesting problems, people
          who self-host their own stuff.
        </p>
      </div>
    </div>
  </div>

  <!-- CTA BANNER -->
  <div class="cta-banner">
    <div class="cta-banner-text">
      <h2>Got something worth<br /><span>building together?</span></h2>
      <p>
        Open to freelance projects, technical discussions, and interesting
        collaborations. If you're self-hosting your own infrastructure, we'll
        probably get along well.
      </p>
    </div>
    <div class="cta-banner-actions">
      <a href="/contact" class="btn-primary">Get In Touch</a>
      <a href="/Resume.pdf" target="_blank" class="btn-outline">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"
          ><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"></path></svg
        >
        Download Resume
      </a>
    </div>
  </div>
</BaseLayout>

<script>
  // Terminal Loading Animation on Viewport Entry
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("animate");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 },
  );

  const terminal = document.querySelector(".mini-terminal");
  if (terminal) observer.observe(terminal);
</script>

<style>
  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 0 52px;
    position: relative;
    overflow: hidden;
  }
  .hero-glow-tl {
    position: absolute;
    top: -120px;
    right: -80px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 59, 59, 0.09) 0%,
      transparent 65%
    );
    pointer-events: none;
  }
  .hero-glow-br {
    position: absolute;
    bottom: -100px;
    left: 30%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 59, 59, 0.04) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 100px;
    position: relative;
    z-index: 2;
  }
  /* eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    border: 1px solid var(--red-border);
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(255, 59, 59, 0.04);
  }
  .hero-tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--red);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.35;
      transform: scale(0.7);
    }
  }
  .hero-loc {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-loc::before {
    content: "◎";
    font-size: 10px;
    color: var(--muted);
  }

  /* headline */
  .hero-h1 {
    font-family: "Syne", sans-serif;
    font-size: clamp(56px, 8.5vw, 108px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -3px;
    margin-bottom: 0;
  }
  .hero-h1 .line {
    display: block;
  }
  .hero-h1 .red {
    color: var(--red);
  }
  .hero-h1 .outline {
    -webkit-text-stroke: 2px rgba(244, 242, 238, 0.25);
    color: transparent;
    transition:
      color 0.3s,
      -webkit-text-stroke 0.3s;
  }
  .hero-h1 .outline:hover {
    color: var(--off);
    -webkit-text-stroke: 2px transparent;
  }

  /* descriptor row */
  .hero-desc-row {
    display: flex;
    align-items: flex-start;
    gap: 64px;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .hero-sub {
    font-size: 16px;
    color: var(--muted);
    max-width: 420px;
    line-height: 1.75;
    flex-shrink: 0;
  }
  .hero-sub strong {
    color: var(--off);
  }
  .hero-tags-inline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: flex-start;
    justify-content: center;
    padding-top: 4px;
    width: 100%;
  }
  .htag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--off2);
    background: rgba(34, 38, 54, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.07);
    padding: 5px 12px;
    border-radius: 5px;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .htag:hover {
    border-color: var(--red-border);
    color: var(--off);
  }

  /* CTA row */
  .hero-ctas {
    margin-top: 44px;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-ctas .sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.08);
    margin: 0 4px;
  }
  .hero-social-inline {
    display: flex;
    gap: 8px;
  }

  /* ── TICKER ── */
  .ticker-wrap {
    overflow: hidden;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: rgba(26, 29, 39, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
  }
  .ticker {
    display: flex;
    width: max-content;
    animation: ticker 30s linear infinite;
  }
  .ticker:hover {
    animation-play-state: paused;
  }
  @keyframes ticker {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .tick-item {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 24px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: color 0.2s;
  }
  .tick-item::after {
    content: "";
    width: 3px;
