---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const allProjects = await getCollection("projects");
const featured = allProjects
  .filter((project) => project.data.featured)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));
---

<BaseLayout
  title="Siddhesh Lakhani — Full Stack Developer & Builder"
  description="Siddhesh Lakhani — Full Stack Engineer from Mumbai. Building production-grade systems with Next.js, Express, Linux. Open to freelance, collabs, and technical discussions."
  activePage="home"
>
  <Fragment slot="head">
    <meta
      name="keywords"
      content="Siddhesh Lakhani, Full Stack Developer, Next.js, FastAPI, Linux, Mumbai, Portfolio, sidlakhani"
    />
  </Fragment>

  <!-- HERO -->
  <section class="hero">
    <div class="grid-bg"></div>
    <div class="hero-glow-tl"></div>
    <div class="hero-glow-br"></div>

    <div class="hero-inner">
      <div class="hero-eyebrow">
        <div class="hero-tag">
          <span class="hero-tag-dot"></span>
          Mumbai, India
        </div>
      </div>

      <h1 class="hero-h1">
        <span class="line">Siddhesh</span>
        <span class="line red">Lakhani</span>
        <span class="line outline">Developer.</span>
      </h1>

      <div class="hero-desc-row">
        <div class="hero-tags-inline">
          <span class="htag">Next.js</span>
          <span class="htag">Express</span>
          <span class="htag">PostgreSQL</span>
          <span class="htag">Docker</span>
          <span class="htag">Rust</span>
          <span class="htag">Arch Linux</span>
          <span class="htag">TypeScript</span>
        </div>
        <p class="hero-sub">
          <strong>Full Stack Engineer</strong> shipping production-grade systems —
          from database schema to pixel-perfect UI. Currently obsessing over
          <strong>Linux internals</strong> and self-hosting everything possible.
        </p>
      </div>

      <div class="hero-ctas">
        <a href="/projects" class="btn-primary">View Projects</a>
        <a href="/contact" class="btn-outline">Let's Talk</a>
        <a href="/Resume.pdf" target="_blank" class="btn-outline">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"
            ><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"></path></svg
          >
          Resume
        </a>
        <div class="sep"></div>
        <div class="hero-social-inline">
          <a
            href="https://github.com/sid-lakhani"
            target="_blank"
            class="social-btn"
            ><svg viewBox="0 0 24 24"
              ><path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path></svg
            ></a
          >
          <a
