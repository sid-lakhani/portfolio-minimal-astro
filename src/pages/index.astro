<style>
  /* ── HERO ── */
  .hero {
    min-height: 100vh;
    display: grid;
    grid-template-rows: 1fr auto;
    padding: 0 52px;
    position: relative;
    overflow: hidden;
  }
  .hero-glow-tl {
    position: absolute;
    top: -120px;
    right: -80px;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 59, 59, 0.09) 0%,
      transparent 65%
    );
    pointer-events: none;
  }
  .hero-glow-br {
    position: absolute;
    bottom: -100px;
    left: 30%;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 59, 59, 0.04) 0%,
      transparent 70%
    );
    pointer-events: none;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 100px;
    position: relative;
    z-index: 2;
  }
  /* eyebrow */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .hero-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
    border: 1px solid var(--red-border);
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(255, 59, 59, 0.04);
  }
  .hero-tag-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--red);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.35;
      transform: scale(0.7);
    }
  }
  .hero-loc {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .hero-loc::before {
    content: "◎";
    font-size: 10px;
    color: var(--muted);
  }

  /* headline */
  .hero-h1 {
    font-family: "Syne", sans-serif;
    font-size: clamp(56px, 8.5vw, 108px);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -3px;
    margin-bottom: 0;
  }
  .hero-h1 .line {
    display: block;
  }
  .hero-h1 .red {
    color: var(--red);
  }
  .hero-h1 .outline {
    -webkit-text-stroke: 2px rgba(244, 242, 238, 0.25);
    color: transparent;
    transition:
      color 0.3s,
      -webkit-text-stroke 0.3s;
  }
  .hero-h1 .outline:hover {
    color: var(--off);
    -webkit-text-stroke: 2px transparent;
  }

  /* descriptor row */
  .hero-desc-row {
    display: flex;
    align-items: flex-start;
    gap: 64px;
    margin-top: 36px;
    flex-wrap: wrap;
  }
  .hero-sub {
    font-size: 16px;
    color: var(--muted);
    max-width: 420px;
    line-height: 1.75;
    flex-shrink: 0;
  }
  .hero-sub strong {
    color: var(--off);
  }
  .hero-tags-inline {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: flex-start;
    padding-top: 4px;
  }
  .htag {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--off2);
    background: var(--char3);
    border: 1px solid rgba(255, 255, 255, 0.07);
    padding: 5px 12px;
    border-radius: 5px;
    transition:
      border-color 0.2s,
      color 0.2s;
  }
  .htag:hover {
    border-color: var(--red-border);
    color: var(--off);
  }

  /* CTA row */
  .hero-ctas {
    margin-top: 44px;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }
  .hero-ctas .sep {
    width: 1px;
    height: 32px;
    background: rgba(255, 255, 255, 0.08);
    margin: 0 4px;
  }
  .hero-social-inline {
    display: flex;
    gap: 8px;
  }

  /* bottom stats bar */
  .hero-bottom {
    position: relative;
    z-index: 2;
    border-top: 1px solid rgba(255, 59, 59, 0.12);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-bottom: 0;
  }
  .hstat {
    padding: 22px 28px;
    border-right: 1px solid rgba(255, 59, 59, 0.1);
    position: relative;
    overflow: hidden;
    transition: background 0.25s;
  }
  .hstat:last-child {
    border-right: none;
  }
  .hstat:hover {
    background: rgba(255, 59, 59, 0.03);
  }
  .hstat-num {
    font-family: "Syne", sans-serif;
    font-size: 28px;
    font-weight: 800;
    color: var(--off);
    display: flex;
    align-items: baseline;
    gap: 2px;
  }
  .hstat-num sup {
    font-size: 14px;
    color: var(--red);
    font-weight: 700;
    margin-left: 2px;
  }
  .hstat-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 3px;
  }
  .hstat-bar {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    background: var(--red);
    width: 0;
    transition: width 0.4s ease;
  }
  .hstat:hover .hstat-bar {
    width: 100%;
  }

  /* ── TICKER ── */
  .ticker-wrap {
    overflow: hidden;
    padding: 16px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--char2);
  }
  .ticker {
    display: flex;
    width: max-content;
    animation: ticker 30s linear infinite;
  }
  .ticker:hover {
    animation-play-state: paused;
  }
  @keyframes ticker {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
  .tick-item {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 24px;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 20px;
    transition: color 0.2s;
  }
  .tick-item::after {
    content: "";
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: rgba(255, 59, 59, 0.5);
  }
  .tick-item:hover {
    color: var(--off);
  }

  /* ── ABOUT STRIP ── */
  .about-strip {
    padding: 100px 52px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .about-strip-left .section-h {
    max-width: 480px;
    margin-top: 14px;
  }
  .about-strip-left .section-sub {
    margin-top: 18px;
  }
  .about-strip-left .ctas {
    margin-top: 36px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .about-strip-right {
  }
  .about-prose p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .about-prose p strong {
    color: var(--off);
  }
  .about-prose p:last-child {
    margin-bottom: 0;
  }

  /* terminal inline */
  .mini-terminal {
    background: var(--char3);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    margin-top: 28px;
  }
  .mini-terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.02);
    border-bottom: 1px solid var(--border);
  }
  .t-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .t-red {
    background: #ff5f57;
  }
  .t-yellow {
    background: #febc2e;
  }
  .t-green {
    background: #28c840;
  }
  .mini-terminal-body {
    padding: 16px 20px;
    font-family: "Space Grotesk", monospace;
    font-size: 12px;
    line-height: 1.8;
  }
  .tc {
    color: var(--muted);
  }
  .tv {
    color: var(--off);
  }
  .tg {
    color: #4ade80;
  }
  .tr {
    color: var(--red);
  }

  /* ── SELECTED WORK ── */
  .work-section {
    padding: 0 52px 100px;
  }
  .work-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 48px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .work-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 2px;
  }
  .wcard {
    background: var(--char2);
    padding: 36px 32px 40px;
    position: relative;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: background 0.2s;
    border: 1px solid rgba(255, 255, 255, 0.03);
  }
  .wcard:hover {
    background: var(--char3);
  }
  .wcard::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, var(--red), transparent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s ease;
  }
  .wcard:hover::after {
    transform: scaleX(1);
  }
  .wcard.featured {
    grid-row: span 2;
    background: var(--char2);
  }
  .wcard.featured:hover {
    background: var(--char3);
  }
  .wcard-num {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 59, 59, 0.5);
    margin-bottom: 20px;
  }
  .wcard-title {
    font-family: "Syne", sans-serif;
    font-size: 20px;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 12px;
  }
  .wcard.featured .wcard-title {
    font-size: 28px;
  }
  .wcard-desc {
    font-size: 13px;
    color: var(--muted);
    line-height: 1.65;
    margin-bottom: 20px;
  }
  .wcard.featured .wcard-desc {
    font-size: 14px;
    max-width: 340px;
  }
  .wcard-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .wcard-tag {
    font-size: 10px;
    font-weight: 700;
    color: var(--red);
    background: rgba(255, 59, 59, 0.08);
    padding: 3px 9px;
    border-radius: 3px;
    border: 1px solid rgba(255, 59, 59, 0.15);
    letter-spacing: 0.03em;
  }
  .wcard-arrow {
    position: absolute;
    top: 32px;
    right: 28px;
    font-size: 16px;
    color: rgba(255, 255, 255, 0.15);
    transition: all 0.25s;
  }
  .wcard:hover .wcard-arrow {
    color: var(--red);
    transform: translate(3px, -3px);
  }

  /* ── PROCESS STRIP ── */
  .process-strip {
    background: var(--char2);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 80px 52px;
  }
  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    margin-top: 48px;
  }
  .proc-item {
    padding: 32px 28px;
    border-right: 1px solid var(--border);
    position: relative;
  }
  .proc-item:last-child {
    border-right: none;
  }
  .proc-step {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 59, 59, 0.4);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
