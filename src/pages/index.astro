    <!-- stats bar pinned to bottom -->
    <div class="hero-bottom">
      <div class="hstat">
        <div class="hstat-num">3<sup>+</sup></div>
        <div class="hstat-label">Years Experience</div>
        <div class="hstat-bar"></div>
      </div>
      <div class="hstat">
        <div class="hstat-num">8<sup>+</sup></div>
        <div class="hstat-label">Projects Shipped</div>
        <div class="hstat-bar"></div>
      </div>
      <div class="hstat">
        <div class="hstat-num">26</div>
        <div class="hstat-label">GitHub Repos</div>
        <div class="hstat-bar"></div>
      </div>
      <div class="hstat">
        <div class="hstat-num">∞</div>
