---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
    title="Gallery — Siddhesh Lakhani"
    description="A visual journal by Siddhesh Lakhani — Mumbai nights, terminal sessions, gaming setups, and the quiet moments between builds."
    activePage="gallery"
>
    <Fragment slot="head">
        <meta
            name="keywords"
            content="Siddhesh Lakhani gallery, Mumbai photography, developer life, Linux setup, tech aesthetic"
        />
        <meta property="og:title" content="Gallery — Siddhesh Lakhani" />
        <meta
            property="og:description"
            content="A visual journal — Mumbai nights, terminal sessions, and the quiet moments between builds."
        />
        <meta property="og:type" content="website" />
        <link rel="canonical" href="https://sidlakhani.in/gallery" />
    </Fragment>

    <div class="page-wrap">
        <!-- GALLERY GRIDS -->
