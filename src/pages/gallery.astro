<style>
    /* ── GALLERY PAGE ── */
    .gal-hero {
        padding: 120px 52px 64px;
        position: relative;
        overflow: hidden;
    }
    .gal-hero .grid-bg {
        opacity: 0.4;
    }
    .gal-hero-inner {
        position: relative;
        z-index: 2;
    }
    .gal-intro {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 80px;
        align-items: end;
        margin-top: 48px;
    }
    .gal-intro-quote {
        font-family: "Syne", sans-serif;
        font-size: clamp(20px, 2.5vw, 28px);
        font-weight: 700;
        color: var(--muted);
        line-height: 1.4;
        letter-spacing: -0.5px;
        border-left: 2px solid var(--red);
        padding-left: 24px;
    }
    .gal-intro-quote em {
        color: var(--off);
        font-style: normal;
    }
    .gal-intro-text {
        font-size: 14px;
        color: var(--muted);
        line-height: 1.8;
    }

    /* ── CHAPTERS ── */
    .chapter {
        padding: 0 52px 96px;
    }
    .chapter-header {
        display: flex;
        align-items: center;
        gap: 20px;
        margin-bottom: 32px;
        padding-bottom: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .chapter-num {
        font-family: "Syne", sans-serif;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255, 59, 59, 0.5);
        flex-shrink: 0;
    }
    .chapter-title {
        font-family: "Syne", sans-serif;
        font-size: 20px;
        font-weight: 700;
        color: var(--off);
    }
    .chapter-desc {
        font-size: 13px;
        color: var(--muted);
        margin-left: auto;
        max-width: 320px;
        line-height: 1.5;
        text-align: right;
    }

    /* ── MASONRY GRID ── */
    .gal-grid {
        columns: 3;
        column-gap: 6px;
        padding: 0 52px;
    }
    .gal-grid:first-of-type {
        padding-top: 64px;
    }
    .gal-item {
        break-inside: avoid;
        margin-bottom: 6px;
        position: relative;
        overflow: hidden;
        border-radius: 4px;
        cursor: pointer;
            display: block;
            background: rgba(26, 29, 39, 0.65);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
    }
    .gal-item:hover .gal-img {
        transform: scale(1.03);
    }
    .gal-item:hover .gal-overlay {
        opacity: 1;
    }
    .gal-img {
        width: 100%;
        display: block;
        transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .gal-img svg {
        width: 100%;
        display: block;
    }
    .gal-overlay {
        position: absolute;
        inset: 0;
        background: rgba(17, 19, 26, 0.3);
        opacity: 0;
        transition: opacity 0.3s;
        pointer-events: none;
    }

    /* ── LIGHTBOX ── */
    #lightbox {
        position: fixed;
        inset: 0;
        z-index: 999;
        background: rgba(10, 11, 16, 0.97);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s;
    }
    #lightbox.open {
        opacity: 1;
        pointer-events: all;
    }
    .lb-inner {
        position: relative;
        max-width: 90vw;
        max-height: 90vh;
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .lb-img {
        max-width: 90vw;
        max-height: 82vh;
        border-radius: 4px;
    }
    .lb-img :global(svg) {
        max-width: 90vw;
        max-height: 82vh;
        display: block;
    }
    .lb-close {
        position: fixed;
        top: 24px;
        right: 28px;
        font-size: 24px;
        color: var(--muted);
        cursor: pointer;
        transition: color 0.2s;
        background: none;
        border: none;
        font-family: "Space Grotesk", sans-serif;
        z-index: 1001;
    }
    .lb-close:hover {
        color: var(--off);
    }
    .lb-nav {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        font-size: 20px;
        color: rgba(255, 255, 255, 0.3);
        cursor: pointer;
        background: none;
        border: none;
        font-family: "Space Grotesk", sans-serif;
        transition: color 0.2s;
        padding: 20px;
        z-index: 1001;
    }
    .lb-nav:hover {
        color: var(--off);
    }
    .lb-prev {
        left: 12px;
    }
    .lb-next {
        right: 12px;
    }
    .lb-counter {
        margin-top: 16px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
    }

    /* ── DIVIDER ── */
    .gal-divider {
        display: flex;
        align-items: center;
        gap: 20px;
        padding: 0 52px 60px;
    }
    .gal-divider-line {
        flex: 1;
        height: 1px;
        background: rgba(255, 255, 255, 0.05);
    }
    .gal-divider-text {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(255, 59, 59, 0.4);
        flex-shrink: 0;
    }

    /* ── FILM STRIP ── */
    .filmstrip {
        overflow: hidden;
        padding: 0 0 96px;
    }
    .filmstrip-inner {
        display: flex;
        gap: 6px;
        width: max-content;
        animation: filmscroll 40s linear infinite;
    }
    .filmstrip-inner:hover {
        animation-play-state: paused;
    }
    @keyframes filmscroll {
        from {
            transform: translateX(0);
        }
        to {
            transform: translateX(-50%);
        }
    }
    .film-item {
        width: 220px;
        height: 160px;
        flex-shrink: 0;
        border-radius: 4px;
            overflow: hidden;
            background: rgba(26, 29, 39, 0.65);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            cursor: pointer;
            position: relative;
    }
    .film-item svg {
        width: 100%;
        height: 100%;
    }
    .film-item:hover {
        opacity: 0.8;
    }

    /* ── END CTA ── */
    .gal-end {
        padding: 0 52px 96px;
        text-align: center;
        position: relative;
    }
    .gal-end-glow {
        position: absolute;
        bottom: -60px;
        left: 50%;
        transform: translateX(-50%);
        width: 500px;
        height: 250px;
        background: radial-gradient(
            circle,
            rgba(255, 59, 59, 0.07) 0%,
            transparent 70%
        );
        pointer-events: none;
    }
    .gal-end h2 {
        font-family: "Syne", sans-serif;
        font-size: clamp(28px, 4vw, 48px);
        font-weight: 800;
        letter-spacing: -1.5px;
        margin-bottom: 14px;
    }
    .gal-end h2 span {
        color: var(--red);
    }
    .gal-end p {
        font-size: 15px;
        color: var(--muted);
        max-width: 400px;
        margin: 0 auto 32px;
        line-height: 1.7;
    }
    .gal-end-btns {
        display: flex;
        justify-content: center;
        gap: 12px;
        flex-wrap: wrap;
    }

    @media (max-width: 900px) {
        .gal-hero,
        .chapter,
        .gal-divider,
        .gal-end {
            padding-left: 20px;
            padding-right: 20px;
        }
        .gal-grid {
            columns: 2;
        }
        .gal-intro {
            grid-template-columns: 1fr;
            gap: 28px;
        }
        .chapter-desc {
            display: none;
        }
    }
    @media (max-width: 500px) {
        .gal-grid {
            columns: 1;
        }
    }
</style>

<script is:inline>
    document.addEventListener("DOMContentLoaded", () => {
        const items = Array.from(document.querySelectorAll(".gal-item"));
        const lightbox = document.getElementById("lightbox");
        const lbImg = document.getElementById("lb-img");
        const lbCounter = document.getElementById("lb-counter");
        const lbClose = document.getElementById("lb-close");
        const lbPrev = document.getElementById("lb-prev");
        const lbNext = document.getElementById("lb-next");
        let current = 0;

        function openLB(idx) {
            current = idx;
            const el = items[idx];
            const imgEl = el.querySelector(".gal-img");
            lbImg.innerHTML = imgEl.innerHTML;
            lbCounter.textContent = idx + 1 + " / " + items.length;
            lightbox.classList.add("open");
            document.body.style.overflow = "hidden";
        }

        function closeLB() {
            lightbox.classList.remove("open");
            document.body.style.overflow = "";
        }

        items.forEach((item, i) => {
            item.addEventListener("click", () => openLB(i));
        });

        lbClose.addEventListener("click", closeLB);

        lightbox.addEventListener("click", (e) => {
            if (e.target === lightbox) closeLB();
        });

        const navLB = (dir) => {
            current = (current + dir + items.length) % items.length;
            openLB(current);
        };

        lbPrev.addEventListener("click", () => navLB(-1));
        lbNext.addEventListener("click", () => navLB(1));

        document.addEventListener("keydown", (e) => {
            if (!lightbox.classList.contains("open")) return;
            if (e.key === "Escape") closeLB();
            if (e.key === "ArrowRight") navLB(1);
            if (e.key === "ArrowLeft") navLB(-1);
        });

        // film strip items
        document.querySelectorAll(".film-item").forEach((fi, i) => {
            fi.addEventListener("click", () => openLB(i % items.length));
        });
    });
</script>
