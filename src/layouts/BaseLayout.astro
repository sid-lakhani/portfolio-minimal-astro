---
import "../styles/global.css";

const { title, description, activePage } = Astro.props as {
  title: string;
  description: string;
  activePage?: "home" | "about" | "projects" | "contact";
};

const siteUrl = Astro.site ?? new URL("https://sidlakhani.in");
const pagePathMap = {
  home: "/",
  about: "/about",
  projects: "/projects",
  contact: "/contact",
};
const canonicalPath = pagePathMap[activePage ?? "home"];
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const socialImageUrl = new URL("/og.png", siteUrl).toString();
